# ── The Nail Hubs backend configuration ─────────────────────────────
# Copy to .env and fill in the values you have. Every integration is
# optional — the site degrades gracefully when a key is missing.

# OpenAI key for the natural-language /ai-chat receptionist (optional;
# the /chat deterministic receptionist works without it)
OPENAI_API_KEY=

# ── Instagram (live feed + stories on the website) ───────────────────
# 1. Convert @thenailhubs to an Instagram Professional account (free)
# 2. Create an app at https://developers.facebook.com → "Instagram API
#    with Instagram Login" → generate a long-lived access token
# 3. Paste it below. Tokens last 60 days — hit GET /instagram/refresh-token
#    monthly and update this value with the returned token.
INSTAGRAM_ACCESS_TOKEN=
# Leave as "me" unless you use a Facebook-Login token tied to a user id
INSTAGRAM_USER_ID=me

# ── Google reviews (live rating + latest reviews) ────────────────────
# 1. Create a key at https://console.cloud.google.com → enable
#    "Places API (New)"
# 2. Find the salon's Place ID at
#    https://developers.google.com/maps/documentation/places/web-service/place-id
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=

# ── Server ───────────────────────────────────────────────────────────
# Comma-separated frontend origins, e.g. https://thenailhubs.vercel.app
ALLOWED_ORIGINS=*
# SQLite path (use a persistent disk in production, /tmp on serverless)
DB_PATH=
PORT=8000
